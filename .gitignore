# Python-generated files
__pycache__/
.pytest_cache/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env
venv/
# Fichiers système
.DS_Store
docker-compose.yml
test*.+.py
.dockerignore
sigaps.txt
*:Zone.Identifier

# =========================================
# GESTION DU DOSSIER DATA 
# =========================================
# 1. On ignore tout le contenu du dossier data par défaut
data/*
# 2. MAIS on autorise Git à "entrer" dans le sous-dossier processed
!data/processed/
# 3. On ignore le contenu de processed (dont les vrais sigaps_ref)
data/processed/*
# 4. MAIS on autorise explicitement et uniquement la démo !
!data/processed/sigaps_demo.csv
!data/processed/sigaps_demo.emb.npy
!data/processed/sigaps_demo.emb.ids


# =========================================
# MODÈLES IA (Mode Air-Gapped)
# =========================================
models/*
!models/.gitkeep
